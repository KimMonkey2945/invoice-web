# invoice-web 환경변수 템플릿
# 이 파일을 복사해 .env.local 을 만들고 실제 값을 채우세요. (.env.local 은 git 에 커밋되지 않습니다)

# 노션 통합(integration) 시크릿 토큰 (server-only, 클라이언트에 노출 금지)
# 노션 → Settings → Connections → 통합 생성 후 발급받은 토큰
NOTION_TOKEN=

# 견적서(Invoices) 데이터베이스 ID
# 노션 데이터베이스 URL의 32자리 ID (하이픈 없이/있이 모두 허용)
# Items(항목) 데이터 소스는 양방향 relation으로 자동 해석되므로 별도 설정 불필요
NOTION_DATABASE_ID=

# (선택) 배포 환경의 절대 URL — 메타데이터 metadataBase 기준점
# 예: https://invoice-web.example.com
NEXT_PUBLIC_APP_URL=
